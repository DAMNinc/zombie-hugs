{
  "name": "zombie-hugs",
  "version": "0.4.0",
  "description": "DAMN good zombie game",
  "main": "dist/server.js",
  "dependencies": {
    "express": "^4.21.0",
    "express-handlebars": "^8.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "three": "0.71.0",
    "unique-names-generator": "^4.7.1",
    "winston": "^3.17.0"
  },
  "engines": {
    "node": ">=20.13.1"
  },
  "scripts": {
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:assets": "mkdir -p public/css public/fonts public/content && cp -r src/css/* public/css/ && cp -r src/fonts/* public/fonts/ && cp -r src/content/* public/content/",
    "build": "npm run build:assets && npm run build:client && npm run build:server",
    "start": "node dist/server.js",
    "dev": "npm run build:assets && concurrently -k \"vite build --watch\" \"tsx watch server.ts\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "DAMN Inc.",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DAMNinc/zombie-hugs.git"
  },
  "bugs": {
    "url": "https://github.com/DAMNinc/zombie-hugs/issues"
  },
  "homepage": "https://github.com/DAMNinc/zombie-hugs"
}
